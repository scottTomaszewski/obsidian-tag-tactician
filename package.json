{
  "name": "tag-tactician",
  "version": "1.10.1",
  "description": "Tag Tactician - Better tag management and organization for Obsidian notes",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "build-no-check": "node esbuild.config.mjs production",
    "lint": "eslint .",
    "test": "jest --passWithNoTests",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "tags",
    "organization"
  ],
  "author": "Scott Tomaszewski (Xentis)",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/language": "^6.10.1",
    "@types/css": "^0.0.37",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^16.11.6",
    "@types/uuid": "^9.0.8",
    "builtin-modules": "3.3.0",
    "css": "^3.0.0",
    "esbuild": "0.17.3",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "obsidian": "latest",
    "ts-jest": "^29.1.4",
    "tslib": "2.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "uuid": "^9.0.1"
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  }
}
